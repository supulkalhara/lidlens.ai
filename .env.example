# FinLens — Secrets Only
# All other configuration is in config.yaml

# ─── Authentication (required) ────────────────────────────────
# Generate NEXTAUTH_SECRET:  openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_32_plus_char_random_string

# Production URL (set to your domain in production, leave blank for local)
NEXTAUTH_URL=http://localhost:3000

# Your dashboard password (for password/access-key login)
AUTH_PASSWORD=your_dashboard_password_here

# ─── Google OAuth (optional — for "Continue with Google") ─────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Restrict Google sign-in to specific emails (comma-separated, leave blank to allow all)
ALLOWED_EMAILS=your@email.com,another@email.com

# ─── LLM Pipeline ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Gmail Integration (optional — future email auto-fetch) ───
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=
GMAIL_USER=your_email@gmail.com
